{
  "id": "cert16-tc048-3-reserve-now-unavailable",
  "name": "Cert 1.6 Reservation: TC_048_3 Reserve Now — Unavailable",
  "description": "Connector set to Unavailable; arm Unavailable response override; CSMS sends ReserveNow; CP responds with Unavailable status; reset to Available.",
  "targetType": "connector",
  "targetId": 1,
  "trigger": { "type": "manual" },
  "defaultExecutionMode": "oneshot",
  "enabled": true,
  "nodes": [
    {
      "id": "start-1",
      "type": "start",
      "position": { "x": 400, "y": 50 },
      "data": { "label": "Start", "triggerOn": "connect" }
    },
    {
      "id": "status-unavailable",
      "type": "statusChange",
      "position": { "x": 400, "y": 150 },
      "data": { "label": "Set Unavailable", "status": "Unavailable" }
    },
    {
      "id": "arm-unavailable-response",
      "type": "responseOverride",
      "position": { "x": 400, "y": 250 },
      "data": {
        "label": "Arm Unavailable response for ReserveNow",
        "action": "ReserveNow",
        "status": "Unavailable"
      }
    },
    {
      "id": "trigger-reserve-now",
      "type": "csmsCallTrigger",
      "position": { "x": 400, "y": 350 },
      "data": {
        "label": "Wait for ReserveNow (will be Unavailable)",
        "action": "ReserveNow",
        "timeout": 0
      }
    },
    {
      "id": "status-available",
      "type": "statusChange",
      "position": { "x": 400, "y": 450 },
      "data": { "label": "Set Available", "status": "Available" }
    },
    {
      "id": "end-1",
      "type": "end",
      "position": { "x": 400, "y": 550 },
      "data": { "label": "End" }
    }
  ],
  "edges": [
    { "id": "e1", "source": "start-1", "target": "status-unavailable" },
    {
      "id": "e2",
      "source": "status-unavailable",
      "target": "arm-unavailable-response"
    },
    {
      "id": "e3",
      "source": "arm-unavailable-response",
      "target": "trigger-reserve-now"
    },
    {
      "id": "e4",
      "source": "trigger-reserve-now",
      "target": "status-available"
    },
    { "id": "e5", "source": "status-available", "target": "end-1" }
  ]
}
