{
  "id": "cert16-tc054-trigger-message",
  "name": "Cert 1.6 RemoteTrigger: TC_054 Trigger Message",
  "description": "CSMS sends TriggerMessage requesting a message type (e.g. StatusNotification, Heartbeat, MeterValues, BootNotification, DiagnosticsStatusNotification, FirmwareStatusNotification). CP answers Accepted and sends the requested message. Re-run the scenario to try further message kinds.",
  "targetType": "connector",
  "targetId": 1,
  "trigger": { "type": "manual" },
  "defaultExecutionMode": "oneshot",
  "enabled": true,
  "nodes": [
    {
      "id": "start-1",
      "type": "start",
      "position": { "x": 400, "y": 50 },
      "data": { "label": "Start", "triggerOn": "connect" }
    },
    {
      "id": "trigger-message",
      "type": "csmsCallTrigger",
      "position": { "x": 400, "y": 250 },
      "data": {
        "label": "Wait for TriggerMessage",
        "action": "TriggerMessage",
        "timeout": 0
      }
    },
    {
      "id": "delay-cp-sends",
      "type": "delay",
      "position": { "x": 400, "y": 350 },
      "data": { "label": "CP sends the requested message", "delaySeconds": 2 }
    },
    {
      "id": "end-1",
      "type": "end",
      "position": { "x": 400, "y": 450 },
      "data": { "label": "End" }
    }
  ],
  "edges": [
    { "id": "e1", "source": "start-1", "target": "trigger-message" },
    { "id": "e3", "source": "trigger-message", "target": "delay-cp-sends" },
    { "id": "e4", "source": "delay-cp-sends", "target": "end-1" }
  ]
}
