{
  "id": "cert16-tc057-central-smart-charging-txprofile",
  "name": "Cert 1.6 SmartCharging: TC_057 Central Smart Charging — TxProfile",
  "description": "Charging session runs with a live transaction; CSMS sends SetChargingProfile with a TxProfile for the running transaction on connector 1. CP validates and stores the profile and applies the schedule, then the scenario stops the transaction and returns to Available.",
  "targetType": "connector",
  "targetId": 1,
  "trigger": { "type": "manual" },
  "defaultExecutionMode": "oneshot",
  "enabled": true,
  "nodes": [
    {
      "id": "start-1",
      "type": "start",
      "position": { "x": 400, "y": 50 },
      "data": { "label": "Start", "triggerOn": "connect" }
    },
    {
      "id": "plug-in",
      "type": "connectorPlug",
      "position": { "x": 400, "y": 150 },
      "data": { "label": "Plug In", "action": "plugin" }
    },
    {
      "id": "tx-start",
      "type": "transaction",
      "position": { "x": 400, "y": 350 },
      "data": {
        "label": "Start Transaction",
        "action": "start",
        "tagId": "CERT057"
      }
    },
    {
      "id": "meter-auto",
      "type": "meterValue",
      "position": { "x": 400, "y": 550 },
      "data": {
        "label": "Unbounded Auto MeterValue",
        "value": 0,
        "sendMessage": true,
        "autoIncrement": true,
        "incrementInterval": 0,
        "incrementAmount": 0,
        "maxTime": 0,
        "maxValue": 0
      }
    },
    {
      "id": "csms-set-charging-profile",
      "type": "csmsCallTrigger",
      "position": { "x": 400, "y": 650 },
      "data": {
        "label": "Wait for SetChargingProfile (TxProfile)",
        "action": "SetChargingProfile",
        "timeout": 0
      }
    },
    {
      "id": "delay-10",
      "type": "delay",
      "position": { "x": 400, "y": 750 },
      "data": { "label": "Delay 10s", "delaySeconds": 10 }
    },
    {
      "id": "tx-stop",
      "type": "transaction",
      "position": { "x": 400, "y": 850 },
      "data": {
        "label": "Stop Transaction",
        "action": "stop"
      }
    },
    {
      "id": "end-1",
      "type": "end",
      "position": { "x": 400, "y": 1150 },
      "data": { "label": "End" }
    }
  ],
  "edges": [
    { "id": "e1", "source": "start-1", "target": "plug-in" },
    { "id": "e2", "source": "plug-in", "target": "tx-start" },
    { "id": "e3", "source": "tx-start", "target": "meter-auto" },
    {
      "id": "e4",
      "source": "meter-auto",
      "target": "csms-set-charging-profile"
    },
    { "id": "e5", "source": "csms-set-charging-profile", "target": "delay-10" },
    { "id": "e6", "source": "delay-10", "target": "tx-stop" },
    { "id": "e7", "source": "tx-stop", "target": "end-1" }
  ]
}
