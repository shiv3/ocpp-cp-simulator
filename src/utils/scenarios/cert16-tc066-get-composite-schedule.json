{
  "id": "cert16-tc066-get-composite-schedule",
  "name": "Cert 1.6 SmartCharging: TC_066 Get Composite Schedule",
  "description": "Parks on SetChargingProfile, then on GetCompositeSchedule (two sequential csmsCallTrigger parks testing re-park path)",
  "targetType": "chargePoint",
  "trigger": { "type": "manual" },
  "defaultExecutionMode": "oneshot",
  "enabled": true,
  "nodes": [
    {
      "id": "start-1",
      "type": "start",
      "position": { "x": 400, "y": 50 },
      "data": { "label": "Start", "triggerOn": "connect" }
    },
    {
      "id": "status-available",
      "type": "statusChange",
      "position": { "x": 400, "y": 150 },
      "data": { "label": "Set Available", "status": "Available" }
    },
    {
      "id": "csms-set-charging-profile",
      "type": "csmsCallTrigger",
      "position": { "x": 400, "y": 250 },
      "data": {
        "label": "Wait for SetChargingProfile",
        "action": "SetChargingProfile",
        "timeout": 0
      }
    },
    {
      "id": "csms-get-composite-schedule",
      "type": "csmsCallTrigger",
      "position": { "x": 400, "y": 350 },
      "data": {
        "label": "Wait for GetCompositeSchedule",
        "action": "GetCompositeSchedule",
        "timeout": 0
      }
    },
    {
      "id": "end-1",
      "type": "end",
      "position": { "x": 400, "y": 450 },
      "data": { "label": "End" }
    }
  ],
  "edges": [
    { "id": "e1", "source": "start-1", "target": "status-available" },
    {
      "id": "e2",
      "source": "status-available",
      "target": "csms-set-charging-profile"
    },
    {
      "id": "e3",
      "source": "csms-set-charging-profile",
      "target": "csms-get-composite-schedule"
    },
    { "id": "e4", "source": "csms-get-composite-schedule", "target": "end-1" }
  ]
}
