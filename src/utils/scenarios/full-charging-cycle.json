{
  "id": "full-charging-cycle",
  "name": "Full Charging Cycle",
  "description": "Complete charging cycle with AutoMeterValue",
  "targetType": "connector",
  "targetId": 1,
  "trigger": { "type": "manual" },
  "defaultExecutionMode": "oneshot",
  "enabled": true,
  "nodes": [
    {
      "id": "start-1",
      "type": "start",
      "position": { "x": 400, "y": 50 },
      "data": { "label": "Start" }
    },
    {
      "id": "status-available",
      "type": "statusChange",
      "position": { "x": 400, "y": 150 },
      "data": { "label": "Set Available", "status": "Available" }
    },
    {
      "id": "transaction-start",
      "type": "transaction",
      "position": { "x": 400, "y": 350 },
      "data": {
        "label": "Start Transaction",
        "action": "start",
        "tagId": "USER001",
        "batteryCapacityKwh": 60,
        "initialSoc": 20
      }
    },
    {
      "id": "meter-auto",
      "type": "meterValue",
      "position": { "x": 400, "y": 550 },
      "data": {
        "label": "Auto MeterValue",
        "value": 0,
        "sendMessage": true,
        "autoIncrement": true,
        "incrementInterval": 5,
        "incrementAmount": 500,
        "maxValue": 25000,
        "maxTime": 300
      }
    },
    {
      "id": "delay-charging",
      "type": "delay",
      "position": { "x": 400, "y": 650 },
      "data": { "label": "Charging Complete", "delaySeconds": 5 }
    },
    {
      "id": "transaction-stop",
      "type": "transaction",
      "position": { "x": 400, "y": 750 },
      "data": { "label": "Stop Transaction", "action": "stop" }
    },
    {
      "id": "end-1",
      "type": "end",
      "position": { "x": 400, "y": 1050 },
      "data": { "label": "End" }
    }
  ],
  "edges": [
    {
      "id": "e-start-available",
      "source": "start-1",
      "target": "status-available"
    },
    {
      "id": "e-available-txstart",
      "source": "status-available",
      "target": "transaction-start"
    },
    {
      "id": "e-txstart-meter",
      "source": "transaction-start",
      "target": "meter-auto"
    },
    {
      "id": "e-meter-delay",
      "source": "meter-auto",
      "target": "delay-charging"
    },
    {
      "id": "e-delay-txstop",
      "source": "delay-charging",
      "target": "transaction-stop"
    },
    {
      "id": "e-txstop-end",
      "source": "transaction-stop",
      "target": "end-1"
    }
  ]
}
